# Orchestrator runtime (devin.baby)
ORCHESTRATOR_PORT=9090
ORCHESTRATOR_DRY_RUN=true
ORCHESTRATOR_CONTROLLER_ENABLED=true

# Kubernetes control plane
SANDBOX_NAMESPACE=devin-sandboxes
FIRECRACKER_NAMESPACE=devin-firecracker
APP_NAMESPACE=devin-app
SANDBOX_DEFAULT_RUNTIME=nextjs

# Execution plane (dry-run uses firecracker-host HTTP API)
FIRECRACKER_HOST_URL=http://localhost:9092
RUNTIME_URL=http://localhost:8081
