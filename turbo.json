{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "WEB_APP_URL"
  ],
  "ui": "tui",
  "tasks": {
    "test": {
      "dependsOn": ["^build"],
      "env": ["CI"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
